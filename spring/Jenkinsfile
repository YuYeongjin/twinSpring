pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
        nodejs 'NodeJS-20'
        jdk 'JDK-17'
    }

    environment {
        DOCKER_IMAGE = 'yeongjin95/twin-spring'
        DOCKER_REGISTRY = 'https://registry.hub.docker.com'
        DOCKER_CREDENTIALS_ID = 'docker-hub-credentials'
    }



    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Frontend') {
            environment {
                    // 모든 npm/npx 실행 시 legacy-peer-deps를 강제로 적용 추후 없에자
                    NPM_CONFIG_LEGACY_PEER_DEPS = 'true'
                }
            steps {
                dir('front') {
                    sh 'npm ci'
                    sh 'npx update-browserslist-db@latest'
                    sh 'CI=false npm run build'
                }
            }
        }

        stage('Build JAR') {
            steps {
                dir('spring') {
                    sh 'chmod +x mvnw'
                    sh './mvnw package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                // 빌드 컨텍스트: ./spring (Dockerfile과 target/*.jar 모두 spring/ 아래에 있음)
                sh "docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} ./spring"
                sh "docker tag ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest"
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: env.DOCKER_CREDENTIALS_ID, usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASSWORD')]) {
                    sh "echo \$DOCKER_PASSWORD | docker login -u \$DOCKER_USER --password-stdin"
                    sh "docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}"
                    sh "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }
        stage('Update Manifest') {
                    steps {
                        withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                            sh """
                                git clone https://${GIT_USER}:${GIT_PASS}@github.com/YuYeongjin/digitalTwinCICD.git
                                cd digitalTwinCICD

                                git config user.name "${GIT_USER}"
                                git config user.email "${GIT_USER}@users.noreply.github.com"

                                sed -i "s|image: yeongjin95/twin-spring:.*|image: yeongjin95/twin-spring:${BUILD_NUMBER}|" spring/deployment/deployment.yaml

                                git add spring/deployment/deployment.yaml
                                git commit -m "update spring image tag to ${BUILD_NUMBER}"
                                git push origin main

                                cd ..
                                rm -rf digitalTwinCICD
                            """
                        }
                    }
                }
    }

    post {
        always {
            sh "docker rmi ${DOCKER_IMAGE}:${BUILD_NUMBER} || true"
            cleanWs()
        }
        success {
            echo "[spring] 빌드 성공 - ${DOCKER_IMAGE}:${BUILD_NUMBER}"
        }
        failure {
            echo "[spring] 빌드 실패"
        }
    }
}
