pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'yeongjin95/twin-agent'
        DOCKER_CREDENTIALS_ID = 'docker-hub-credentials'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Lint with Auto-pip') {
            steps {
                dir('agent') {
                    sh '''
                        if ! command -v pip &> /dev/null; then
                            sudo apt-get update && sudo apt-get install -y python3-pip || \
                            (apt-get update && apt-get install -y python3-pip)

                            if ! command -v pip &> /dev/null && command -v pip3 &> /dev/null; then
                                ln -s /usr/bin/pip3 /usr/bin/pip || true
                            fi
                        fi

                        pip install flake8 --quiet --break-system-packages 2>/dev/null \
                            || pip install flake8 --quiet

                        flake8 . --exclude=__pycache__,chroma_db,.env --max-line-length=120 || true
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('agent') {
                    sh "docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} ."
                    sh "docker tag ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: env.DOCKER_CREDENTIALS_ID, usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASSWORD')]) {
                    sh "echo \$DOCKER_PASSWORD | docker login -u \$DOCKER_USER --password-stdin"
                    sh "docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}"
                    sh "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${DOCKER_IMAGE}:${BUILD_NUMBER} || true"
            sh "docker rmi ${DOCKER_IMAGE}:latest || true"
            cleanWs()
        }
        success {
            echo "[agent] 빌드 성공 - ${DOCKER_IMAGE}:${BUILD_NUMBER}"
        }
        failure {
            echo "[agent] 빌드 실패"
        }
    }
}