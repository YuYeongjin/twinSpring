# Ollama (라즈베리파이에서 실행)
# 같은 기기에서 실행 시: http://localhost:11434
# 원격 라즈베리파이: http://<raspberry-pi-ip>:11434
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:1b-instruct-q4_K_M

# MariaDB (docker-compose 기본값)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=digital_twin
DB_USER=root
DB_PASSWORD=1234

# ChromaDB (RAG 벡터스토어)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=twin_docs
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Spring Boot URL (BIM Builder 노드)
SPRING_BASE_URL=http://localhost:8080
