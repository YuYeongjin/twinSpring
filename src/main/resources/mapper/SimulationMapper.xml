<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="yyj.project.twinspring.dao.SimulationDAO">

    <select id="getAllSimulationProjects" resultType="map">
        SELECT project_id   AS projectId,
               project_name AS projectName
        FROM simulation_project
        ORDER BY created_at ASC
    </select>

    <insert id="insertSimulationProject" parameterType="map">
        INSERT INTO simulation_project (project_id, project_name)
        VALUES (#{projectId}, #{projectName})
    </insert>

    <update id="updateSimulationProjectName" parameterType="map">
        UPDATE simulation_project
        SET project_name = #{projectName}
        WHERE project_id = #{projectId}
    </update>

    <delete id="deleteSimulationProject" parameterType="string">
        DELETE FROM simulation_project
        WHERE project_id = #{projectId}
    </delete>

</mapper>
