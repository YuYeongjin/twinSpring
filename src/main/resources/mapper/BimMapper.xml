<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="yyj.project.twinspring.dao.BimDAO">

    <!-- ============================================================
         BIM 레이어 (bim_layer)
         ============================================================ -->

    <!-- 프로젝트의 모든 레이어 조회 (sort_order ASC) -->
    <select id="getLayersByProject" parameterType="string" resultType="map">
        SELECT layer_id    AS layerId,
               project_id  AS projectId,
               layer_name  AS layerName,
               color,
               visible,
               element_ids AS elementIds,
               sort_order  AS sortOrder
        FROM bim_layer
        WHERE project_id = #{projectId}
        ORDER BY sort_order ASC, created_at ASC
    </select>

    <!-- 레이어 신규 삽입 -->
    <insert id="insertLayer" parameterType="map">
        INSERT INTO bim_layer (layer_id, project_id, layer_name, color, visible, element_ids, sort_order)
        VALUES (#{layerId}, #{projectId}, #{layerName}, #{color}, #{visible}, #{elementIds}, #{sortOrder})
    </insert>

    <!-- 레이어 수정 (이름·색상·가시성·부재목록·순서) -->
    <update id="updateLayer" parameterType="map">
        UPDATE bim_layer
        SET layer_name  = #{layerName},
            color       = #{color},
            visible     = #{visible},
            element_ids = #{elementIds},
            sort_order  = #{sortOrder}
        WHERE layer_id = #{layerId}
    </update>

    <!-- 단일 레이어 삭제 -->
    <delete id="deleteLayer" parameterType="string">
        DELETE FROM bim_layer
        WHERE layer_id = #{layerId}
    </delete>

    <!-- 프로젝트의 모든 레이어 삭제 (프로젝트 삭제 연동) -->
    <delete id="deleteLayersByProject" parameterType="string">
        DELETE FROM bim_layer
        WHERE project_id = #{projectId}
    </delete>

    <!-- ============================================================
         BIM 부재 커스텀 색상 (bim_element_color)
         ============================================================ -->

    <!-- 프로젝트의 모든 커스텀 색상 조회 -->
    <select id="getColorsByProject" parameterType="string" resultType="map">
        SELECT element_id AS elementId,
               project_id AS projectId,
               color
        FROM bim_element_color
        WHERE project_id = #{projectId}
    </select>

    <!-- 색상 저장(없으면 INSERT, 있으면 UPDATE) -->
    <insert id="upsertColor" parameterType="map">
        INSERT INTO bim_element_color (element_id, project_id, color)
        VALUES (#{elementId}, #{projectId}, #{color})
        ON DUPLICATE KEY UPDATE color = #{color}
    </insert>

    <!-- 단일 부재 색상 삭제 -->
    <delete id="deleteColor" parameterType="string">
        DELETE FROM bim_element_color
        WHERE element_id = #{elementId}
    </delete>

    <!-- 프로젝트의 모든 커스텀 색상 삭제 -->
    <delete id="deleteColorsByProject" parameterType="string">
        DELETE FROM bim_element_color
        WHERE project_id = #{projectId}
    </delete>

    <!-- ============================================================
         BIM 선 (bim_line)
         필요 DDL:
         CREATE TABLE bim_line (
             line_id    VARCHAR(64)  NOT NULL PRIMARY KEY,
             project_id VARCHAR(64)  NOT NULL,
             start_x    DOUBLE       NOT NULL DEFAULT 0,
             start_y    DOUBLE       NOT NULL DEFAULT 0,
             start_z    DOUBLE       NOT NULL DEFAULT 0,
             end_x      DOUBLE       NOT NULL DEFAULT 0,
             end_y      DOUBLE       NOT NULL DEFAULT 0,
             end_z      DOUBLE       NOT NULL DEFAULT 0,
             color      VARCHAR(20)  NOT NULL DEFAULT '#60a5fa',
             line_width DOUBLE       NOT NULL DEFAULT 2,
             created_at TIMESTAMP    NOT NULL DEFAULT CURRENT_TIMESTAMP,
             INDEX idx_bim_line_project (project_id)
         );
         ============================================================ -->

    <select id="getLinesByProject" parameterType="string" resultType="map">
        SELECT line_id    AS lineId,
               project_id AS projectId,
               start_x    AS startX,
               start_y    AS startY,
               start_z    AS startZ,
               end_x      AS endX,
               end_y      AS endY,
               end_z      AS endZ,
               color,
               line_width AS lineWidth
        FROM bim_line
        WHERE project_id = #{projectId}
        ORDER BY created_at ASC
    </select>

    <insert id="insertLine" parameterType="map">
        INSERT INTO bim_line (line_id, project_id, start_x, start_y, start_z, end_x, end_y, end_z, color, line_width)
        VALUES (#{lineId}, #{projectId}, #{startX}, #{startY}, #{startZ}, #{endX}, #{endY}, #{endZ}, #{color}, #{lineWidth})
    </insert>

    <delete id="deleteLine" parameterType="string">
        DELETE FROM bim_line WHERE line_id = #{lineId}
    </delete>

    <delete id="deleteLinesByProject" parameterType="string">
        DELETE FROM bim_line WHERE project_id = #{projectId}
    </delete>

</mapper>
