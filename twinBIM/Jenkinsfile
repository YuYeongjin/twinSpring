pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'yeongjin95/twin-bim'
        DOCKER_CREDENTIALS_ID = 'docker-hub-credentials'
        DOTNET_VERSION = '8.0'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Restore') {
            steps {
                dir('twinBIM') {
                    sh 'dotnet restore'
                }
            }
        }

        stage('Build') {
            steps {
                dir('twinBIM') {
                    sh 'dotnet build --configuration Release --no-restore'
                }
            }
        }

        stage('Publish (linux-x64)') {
            steps {
                dir('twinBIM') {
                    sh '''
                        dotnet publish \
                            --configuration Release \
                            --runtime linux-x64 \
                            --self-contained true \
                            --output publish-amd64 \
                            /p:PublishSingleFile=true \
                            /p:PublishTrimmed=false
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('twinBIM') {
                    sh "docker build --build-arg TARGETARCH=amd64 -t ${DOCKER_IMAGE}:${BUILD_NUMBER} ."
                    sh "docker tag ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: env.DOCKER_CREDENTIALS_ID, usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASSWORD')]) {
                    sh "echo \$DOCKER_PASSWORD | docker login -u \$DOCKER_USER --password-stdin"
                    sh "docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}"
                    sh "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }
        stage('Update Manifest') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                    sh """
                        git clone https://${GIT_USER}:${GIT_PASS}@github.com/YuYeongjin/digitalTwinCICD.git
                        cd digitalTwinCICD

                        git config user.name "${GIT_USER}"
                        git config user.email "${GIT_USER}@users.noreply.github.com"

                        sed -i "s|image: yeongjin95/twin-bim:.*|image: yeongjin95/twin-bim:${BUILD_NUMBER}|" bim/deployment/deployment.yaml

                        git add bim/deployment/deployment.yaml
                        git commit -m "update bim image tag to ${BUILD_NUMBER}"
                        git push origin main

                        cd ..
                        rm -rf digitalTwinCICD
                    """
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${DOCKER_IMAGE}:${BUILD_NUMBER} || true"
            dir('twinBIM') {
                sh 'rm -rf publish-amd64 || true'
            }
            cleanWs()
        }
        success {
            echo "[dotnet] 빌드 성공 - ${DOCKER_IMAGE}:${BUILD_NUMBER}"
        }
        failure {
            echo "[dotnet] 빌드 실패"
        }
    }
}